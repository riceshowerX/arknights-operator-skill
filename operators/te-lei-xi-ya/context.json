          "type": "soothe",
          "label": "安抚",
          "confidence": 0.75
        }
      ],
      "emotion": {}
    },
    {
      "id": "V010",
      "text": "......我在。",
      "source": "voice",
      "source_detail": "干员报到",
      "context": {
        "phase": "resurrected",
        "scene": "干员报到",
        "interlocutor": null,
        "preceding_event": "",
        "situation_type": "casual"
