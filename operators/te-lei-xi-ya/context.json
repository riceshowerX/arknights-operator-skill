        "scene": "精英化晋升1",
        "interlocutor": null,
        "preceding_event": "",
        "situation_type": "casual"
      },
      "speech_acts": [],
      "emotion": {}
    },
    {
      "id": "V013",
      "text": "我知道，还有许多人需要我。不用着急，这一次我不会离开了。",
